# For production (Vercel): requests go to /api/v1 on the same origin,
# then vercel.json rewrites proxy them to the EC2 backend server-side.
# For local dev: use http://localhost:4000/api/v1 instead.

VITE_API_URL=/api/v1

# Uncomment the line below (and comment the one above) for local development:
# VITE_API_URL=http://localhost:4000/api/v1
